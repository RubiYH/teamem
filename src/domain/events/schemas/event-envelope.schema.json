{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://teamem.dev/schemas/event-envelope.schema.json",
  "title": "Teamem Event Envelope",
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "idempotency_key",
    "space_id",
    "timestamp",
    "principal",
    "actor",
    "delegation",
    "event_type",
    "scope",
    "payload"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "event_id": { "type": "string" },
    "idempotency_key": { "type": "string" },
    "space_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "principal": { "type": "string" },
    "actor": { "type": "string" },
    "delegation": { "type": "string" },
    "sprint_id": { "type": ["string", "null"], "minLength": 1 },
    "delivery_scope": { "enum": ["direct", "sprint", "space"] },
    "recipient_principals": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "event_type": {
      "type": "string",
      "enum": [
        "scope_claimed",
        "scope_released",
        "task_started",
        "task_progressed",
        "task_completed",
        "decision_published",
        "decision_amended",
        "decision_superseded",
        "decision_recorded",
        "contract_changed",
        "blocker_raised",
        "blocker_resolved",
        "conflict_detected",
        "conflict_queued",
        "conflict_resolved",
        "acknowledgment_recorded",
        "discussion_posted",
        "space_wiped",
        "space_unwiped",
        "finding_shared",
        "artifact_shared",
        "permission_requested",
        "permission_granted",
        "permission_denied",
        "permission_expired",
        "agent_focus_changed",
        "dispute_opened",
        "dispute_resolved",
        "dispute_terminated",
        "scope_released_via_git",
        "claim_force_released",
        "claim_paused",
        "claim_resumed",
        "claim_expired",
        "space_rule_added",
        "space_rule_amended",
        "space_rule_disabled",
        "sprint_created",
        "sprint_joined",
        "sprint_left",
        "sprint_archived",
        "sprint_reopened"
      ]
    },
    "scope": { "type": "object" },
    "payload": { "type": "object" },
    "refs": { "type": "object" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": true,
  "allOf": [
    {
      "$comment": "New explicit routing metadata. Legacy events may omit delivery_scope and are inferred at read time by runtime code.",
      "if": {
        "properties": { "delivery_scope": { "const": "direct" } },
        "required": ["delivery_scope"]
      },
      "then": {
        "required": ["recipient_principals"],
        "properties": {
          "recipient_principals": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    {
      "$comment": "Sprint/Space fanout derives recipients from membership and must not snapshot recipient principals.",
      "if": {
        "properties": { "delivery_scope": { "enum": ["sprint", "space"] } },
        "required": ["delivery_scope"]
      },
      "then": {
        "properties": {
          "recipient_principals": { "maxItems": 0 }
        }
      }
    },
    {
      "$comment": "Sprint delivery requires non-null sprint_id.",
      "if": {
        "properties": { "delivery_scope": { "const": "sprint" } },
        "required": ["delivery_scope"]
      },
      "then": {
        "required": ["sprint_id"],
        "properties": { "sprint_id": { "type": "string", "minLength": 1 } }
      }
    },
    {
      "$comment": "Space delivery must not overload sprint_id; event-specific payload fields such as affected_sprint_id carry related Sprint metadata.",
      "if": {
        "properties": { "delivery_scope": { "const": "space" } },
        "required": ["delivery_scope"]
      },
      "then": {
        "required": ["sprint_id"],
        "properties": { "sprint_id": { "type": "null" } }
      }
    },
    {
      "$comment": "Sprint lifecycle events carry projection-critical payload fields. Public publishEvent validation must reject malformed Sprint rows before replay can derive corrupt projections.",
      "if": {
        "properties": { "event_type": { "const": "sprint_created" } },
        "required": ["event_type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["sprint_id", "slug", "display_name", "goal"],
            "properties": {
              "sprint_id": { "type": "string", "minLength": 1 },
              "slug": { "type": "string", "minLength": 1 },
              "display_name": { "type": "string", "minLength": 1 },
              "goal": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    {
      "$comment": "Sprint lifecycle events require target identity so projection replay can rebuild current Sprint status and membership.",
      "if": {
        "properties": {
          "event_type": {
            "enum": [
              "sprint_joined",
              "sprint_left",
              "sprint_archived",
              "sprint_reopened"
            ]
          }
        },
        "required": ["event_type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["sprint_id", "slug"],
            "properties": {
              "sprint_id": { "type": "string", "minLength": 1 },
              "slug": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    {
      "$comment": "Codex F25 — dispute_opened payload must carry opened_by + target_principal so the auto-negotiator can derive side without re-query (see ADR-0002, slice #24 F22 fix).",
      "if": {
        "properties": { "event_type": { "const": "dispute_opened" } },
        "required": ["event_type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["opened_by", "target_principal"],
            "properties": {
              "opened_by": { "type": "string", "minLength": 1 },
              "target_principal": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    {
      "$comment": "Codex F25 — discussion_posted events whose payload.dispute_move is set are dispute moves and MUST carry the same opener/target metadata as dispute_opened, for the same reason. Plain discussion_posted events (no dispute_move) are unconstrained.",
      "if": {
        "properties": {
          "event_type": { "const": "discussion_posted" },
          "payload": {
            "type": "object",
            "required": ["dispute_move"]
          }
        },
        "required": ["event_type", "payload"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["opened_by", "target_principal"],
            "properties": {
              "opened_by": { "type": "string", "minLength": 1 },
              "target_principal": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  ]
}
