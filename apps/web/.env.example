# Teamem Cloud web environment
#
# Copy this file to `.env.local` from the repository root:
#   cp apps/web/.env.example apps/web/.env.local
#
# Never commit real `.env.local` files.

NODE_ENV=development

# Canonical web origin.
TEAMEM_CLOUD_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# OAuth providers.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional Google OAuth. Provide both values or leave both empty.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase and control-plane database.
SUPABASE_POSTGRES_URL=
SUPABASE_POSTGRES_CA_CERT=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Hosted Teamem runtime used for Space provisioning.
TEAMEM_CLOUD_RUNTIME_URL=http://localhost:8787
TEAMEM_CLOUD_RUNTIME_PROVISIONING_TOKEN=

# PostHog analytics. Use https://eu.i.posthog.com for EU projects.
NEXT_PUBLIC_POSTHOG_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional deploy-smoke override when Better Auth table names are customized.
# TEAMEM_CLOUD_BETTER_AUTH_TABLES=user,session,account,verification
