# Teamem server environment
#
# Copy this file to `.env` for local development or Docker Compose:
#   cp .env.example .env
#
# Never commit real `.env` files. Generate the JWT secret with:
#   openssl rand -hex 32

NODE_ENV=development
PORT=3000

# Public HTTPS origin for this Teamem runtime.
# Required for managed Teamem Cloud provisioning so dashboard setup commands
# show a reachable server URL instead of falling back to localhost.
# Example: TEAMEM_PUBLIC_URL=https://runtime.teamem.cc
TEAMEM_PUBLIC_URL=

# SQLite database path.
# - Bun local dev uses this path directly.
# - docker-compose.yml overrides this to /app/data/teamem.db and stores it in
#   the `teamem-data` Docker volume.
TEAMEM_DB_PATH=./data/teamem.db

# Migration files used by local `bun run server`.
# docker-compose.yml overrides this to /app/src/infra/db/migrations.
TEAMEM_MIGRATIONS_DIR=./src/infra/db/migrations

# Required by the server. Must be at least 32 characters.
# Generate one with: openssl rand -hex 32
TEAMEM_JWT_SECRET=

# Required only when this runtime accepts managed Teamem Cloud provisioning.
# Must match the web app's TEAMEM_CLOUD_RUNTIME_PROVISIONING_TOKEN.
# Generate one with: openssl rand -hex 32
TEAMEM_CLOUD_RUNTIME_PROVISIONING_TOKEN=

# Comma-separated allowed origins for Streamable HTTP/MCP clients.
# Leave empty for the default same-origin/server-to-server posture.
# Example: TEAMEM_TRUSTED_ORIGINS=https://claude.ai,https://example.com
TEAMEM_TRUSTED_ORIGINS=

# Set to 1 only when running behind a trusted reverse proxy that sets
# X-Forwarded-For; otherwise rate limiting uses the direct peer IP.
# Use 1 for typical HTTPS reverse proxies such as Caddy or nginx on a VPS.
TEAMEM_TRUST_PROXY=0

# Optional maintenance interval overrides in milliseconds.
# TEAMEM_DISBAND_GC_INTERVAL_MS=3600000
# TEAMEM_PENDING_EDITS_GC_INTERVAL_MS=3600000
